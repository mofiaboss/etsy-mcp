# etsy-mcp environment variables
#
# Copy to .env and fill in your values. NEVER commit .env.
# The .gitignore blocks .env but allows .env.example.

# -----------------------------------------------------------------------------
# REQUIRED: Etsy app credentials
# -----------------------------------------------------------------------------
# Register a new app at https://www.etsy.com/developers/your-apps
# Callback URL: http://localhost:3456/callback

ETSY_KEYSTRING=your_etsy_app_keystring_here
ETSY_SHARED_SECRET=your_etsy_app_shared_secret_here

# -----------------------------------------------------------------------------
# OPTIONAL: Token storage location
# -----------------------------------------------------------------------------
# Default: ~/.config/etsy-mcp/tokens.json
# ETSY_TOKEN_STORE=/custom/path/tokens.json

# -----------------------------------------------------------------------------
# OPTIONAL: Refresh token fallback (for headless / CI environments)
# -----------------------------------------------------------------------------
# If set, skips the interactive `etsy-mcp auth login` bootstrap.
# Obtain this by running `etsy-mcp auth login` once on an interactive machine.
# ETSY_REFRESH_TOKEN=

# -----------------------------------------------------------------------------
# OPTIONAL: API base URL (override for testing)
# -----------------------------------------------------------------------------
# Default: https://api.etsy.com/v3/application
# ETSY_API_BASE=https://api.etsy.com/v3/application

# -----------------------------------------------------------------------------
# OPTIONAL: Rate limiting
# -----------------------------------------------------------------------------
# ETSY_RATE_LIMIT_PER_SECOND=10
# ETSY_RATE_LIMIT_PER_DAY=10000
# ETSY_TIMEOUT_SECONDS=15

# -----------------------------------------------------------------------------
# OPTIONAL: Logging
# -----------------------------------------------------------------------------
# ETSY_LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# OPTIONAL: Permission modes (matches unifi-mcp convention)
# -----------------------------------------------------------------------------
# Default: confirm (preview-then-confirm for all mutations)
# Set to: bypass (auto-execute all mutations, for automation contexts)
# ETSY_TOOL_PERMISSION_MODE=confirm

# -----------------------------------------------------------------------------
# OPTIONAL: Policy gates (hard boundaries on destructive actions)
# -----------------------------------------------------------------------------
# Three-level env var hierarchy (most specific wins):
#   ETSY_POLICY_<CATEGORY>_<ACTION> > ETSY_POLICY_<ACTION>
# Actions: CREATE, UPDATE, DELETE
# Unset = allowed. Set to false/0/no/off to disable.

# Examples (uncomment to enable safer defaults):
# ETSY_POLICY_LISTINGS_DELETE=false
# ETSY_POLICY_SHOPS_DELETE=false
# ETSY_POLICY_DELETE=false

# -----------------------------------------------------------------------------
# OPTIONAL: Integration tests gate
# -----------------------------------------------------------------------------
# Set to 1 to run integration tests that hit your real Etsy shop.
# Tests are idempotent and clean up via a session-scoped cleanup registry,
# but they do make real API calls against your account.
# ETSY_INTEGRATION_TESTS=0
